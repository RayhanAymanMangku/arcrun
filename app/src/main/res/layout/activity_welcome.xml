<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                xmlns:tools="http://schemas.android.com/tools"
                android:id="@+id/main"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="30dp"
                android:background="@color/white">

    <!-- Header -->
    <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Welcome"
            android:textSize="14sp"
            android:layout_marginStart="30dp"
            android:textStyle="bold"/>

    <ImageView
            android:id="@+id/profileButton"
            android:layout_width="40dp"
            android:layout_height="50dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="30dp"
            android:src="@drawable/default_profile_image"/>

    <TextView
            android:id="@+id/textViewAyman"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/textView"
            android:text="Ayman"
            android:layout_marginStart="30dp"
            android:textSize="24dp"/>

    <!-- ScrollView for Cards -->
    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/textViewAyman"
            android:layout_marginTop="20dp">

        <LinearLayout
                android:id="@+id/cardContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Control Your Running Now!"
                    android:textSize="20sp"
                    android:layout_marginStart="30dp"
                    android:textStyle="bold"/>

            <!-- First Card -->
            <com.google.android.material.card.MaterialCardView
                    android:id="@+id/addProgramButton"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:layout_marginHorizontal="30dp"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/program"
                        android:padding="20dp">

                    <TextView
                            android:id="@+id/textViewCreateProgram"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Create your own program"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#fff"
                            android:layout_alignParentStart="true"
                            android:layout_alignParentTop="true"/>

                    <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentEnd="true"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/circle_backround_arrow">

                        <ImageView
                                android:id="@+id/addProgramImage"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_arrow_right"
                                android:tint="#000000"/>
                    </FrameLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Second Card -->
            <com.google.android.material.card.MaterialCardView
                    android:id="@+id/achievementButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="30dp"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:background="@drawable/achievement1"
                        android:padding="20dp">

                    <TextView
                            android:id="@+id/textViewAchievements"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Achievements"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#fff"
                            android:layout_alignParentStart="true"
                            android:layout_alignParentTop="true"/>

                    <TextView
                            android:id="@+id/textViewNoAchievements"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No achievements available"
                            android:textSize="16sp"
                            android:textColor="#fff"
                            android:layout_below="@id/textViewAchievements"
                            android:layout_marginTop="10dp"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Education for your health"
                    android:layout_marginStart="30dp"
                    android:layout_marginTop="20dp"
                    android:textStyle="bold"
                    android:textSize="20sp"/>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Increase your health 2x!"
                    android:layout_marginStart="30dp"
                    android:textStyle="normal"
                    android:textSize="14sp"/>

            <!-- Third Card -->
            <com.google.android.material.card.MaterialCardView
                    android:id="@+id/healthEduButton"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:layout_marginHorizontal="30dp"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/healthedu"
                        android:padding="20dp">

                    <TextView
                            android:id="@+id/textViewHealthEdu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Why Running is Good for Health"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#fff"
                            android:layout_alignParentStart="true"
                            android:layout_alignParentTop="true"/>

                    <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentEnd="true"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/circle_backround_arrow">

                        <ImageView
                                android:id="@+id/healthEduImage"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_arrow_right"
                                android:tint="#000000"/>
                    </FrameLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>